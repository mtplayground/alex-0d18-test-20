# Runtime
NODE_ENV=development
HOST=0.0.0.0
PORT=8080
SELF_URL=http://localhost:5173

# PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/app

# myClawTeam auth service. Google sign-in is handled by auth.mctai.app.
MCTAI_AUTH_URL=https://auth.mctai.app
MCTAI_AUTH_APP_TOKEN=replace-with-app-token
MCTAI_AUTH_JWKS_URL=https://auth.mctai.app/.well-known/jwks.json

# App-issued JWT support, if a later feature needs it.
JWT_SECRET=replace-with-at-least-32-random-characters

# Tigris S3-compatible object storage.
# Always prepend S3_PREFIX to every object key used with S3 operations.
S3_ACCESS_KEY_ID=replace-with-access-key
S3_SECRET_ACCESS_KEY=replace-with-secret-key
S3_BUCKET=replace-with-bucket
S3_PREFIX=app_prefix/
S3_ENDPOINT=https://fly.storage.tigris.dev
S3_REGION=auto
S3_FORCE_PATH_STYLE=true
S3_PUBLIC_BASE_URL=https://replace-with-public-base-url

# Frontend
VITE_API_BASE_URL=http://localhost:8080
VITE_APP_ENV=development
